{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Pintra Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "pnpm: watch"
		}
	]
}